df['order_purchase_timestamp'] = pd.to_datetime(df['order_purchase_timestamp'])
df['order_delivered_customer_date'] = pd.to_datetime(df['order_delivered_customer_date'])
df['delivery_time_days'] = (df['order_delivered_customer_date'] - df['order_purchase_timestamp']).dt.days

plt.figure(figsize=(12, 7))
sns.histplot(df['delivery_time_days'].dropna(), bins=50, kde=True, color='skyblue')
plt.axvline(df['delivery_time_days'].median(), color='red', linestyle='--', label=f'Median Delivery Time: {df["delivery_time_days"].median():.0f} days')
plt.title('Distribution of Order Delivery Time', fontsize=16)
plt.xlabel('Delivery Time (Days)', fontsize=12)
plt.ylabel('Number of Orders', fontsize=12)
plt.legend()
plt.grid(True, linestyle='--', alpha=0.7)
plt.tight_layout()
plt.savefig(r"/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/8559bcab-fc16-427c-965f-5993e6e53fea/delivery_time_distribution.png")
