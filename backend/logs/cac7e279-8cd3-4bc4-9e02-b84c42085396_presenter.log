# Calculate total revenue per product category
category_revenue = df.groupby('product_category_name')['price'].sum().sort_values(ascending=False)

# Get the top 10 product categories
top_10_categories = category_revenue.head(10)

# Create the bar plot
plt.figure(figsize=(12, 8))
sns.barplot(x=top_10_categories.values, y=top_10_categories.index, hue=top_10_categories.index, palette='muted', legend=False)

# Add title and labels
plt.title('Top 10 Product Categories by Total Revenue', fontsize=16)
plt.xlabel('Total Revenue', fontsize=12)
plt.ylabel('Product Category', fontsize=12)

# Add annotations for each bar
for index, value in enumerate(top_10_categories.values):
    plt.text(value, index, f'{value:,.2f}', va='center', ha='left', fontsize=10)

plt.tight_layout()
chart_path = r"/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/cac7e279-8cd3-4bc4-9e02-b84c42085396/top_10_product_categories_revenue.png"
plt.savefig(chart_path)
plt.close('all')
print(f"Chart saved to {chart_path}")

