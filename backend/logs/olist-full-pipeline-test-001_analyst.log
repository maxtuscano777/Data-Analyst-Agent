df_model = df.copy()

# Apply pd.get_dummies() to 'product_category_name'
df_model = pd.get_dummies(df_model, columns=['product_category_name'], prefix='category', dummy_na=False)

# Columns for median imputation
median_cols = [
    'product_name_lenght', 'product_description_lenght', 'product_photos_qty',
    'product_weight_g', 'product_length_cm', 'product_height_cm', 'product_width_cm'
]

# Fill nulls with their respective medians
for col in median_cols:
    df_model[col] = df_model[col].fillna(df_model[col].median())

# Drop any remaining object-dtype columns
object_cols = df_model.select_dtypes(include=['object']).columns
df_model = df_model.drop(columns=object_cols)

# Define features (X) and target (y)
# Exclude 'price' itself and any other columns that are not features for predicting price
# Also exclude 'total_item_revenue' as it's derived from 'price'
X = df_model.drop(columns=['price', 'total_item_revenue', 'delivery_duration', 'delivery_delay'])
y = df_model['price']

# Align columns after dropping NaNs in y
X, y = X.align(y, join='inner', axis=0)

# Drop rows with NaN in target variable if any
X = X.dropna(subset=y.name)
y = y.dropna()

# Ensure X and y have the same index after dropping NaNs
X = X.loc[y.index]


# Linear Regression
lr = LinearRegression()
lr_scores = cross_val_score(lr, X, y, cv=5, scoring='r2')
lr_mean = lr_scores.mean()
lr_std = lr_scores.std()

# Decision Tree Regressor
dt = DecisionTreeRegressor(random_state=42)
dt_scores = cross_val_score(dt, X, y, cv=5, scoring='r2')
dt_mean = dt_scores.mean()
dt_std = dt_scores.std()

print(f"Linear Regression CV R2: Mean = {lr_mean:.4f}, Std = {lr_std:.4f}")
print(f"Decision Tree Regressor CV R2: Mean = {dt_mean:.4f}, Std = {dt_std:.4f}")
print('Step 6 done')

# Store results for summary
model_evaluations = [
    {"model_name": "Linear Regression", "cv_r2_mean": lr_mean, "cv_r2_std": lr_std, "selected": False},
    {"model_name": "Decision Tree Regressor", "cv_r2_mean": dt_mean, "cv_r2_std": dt_std, "selected": False}
]

# Select the better performing model (higher mean R2)
if lr_mean >= dt_mean:
    model_evaluations[0]["selected"] = True
else:
    model_evaluations[1]["selected"] = True

# Store insights for summary
insights = [
    f"The top revenue-generating product category is '{top_revenue_categories.index[0]}' with a total revenue of {top_revenue_categories.iloc[0]:.2f}.",
    f"The product category with the highest average delivery delay is '{top_late_delivery_categories.index[0]}' with an average delay of {top_late_delivery_categories.iloc[0]:.2f} days.",
    f"Linear Regression model achieved a mean R2 score of {lr_mean:.4f} (std: {lr_std:.4f}) across 5-fold cross-validation for predicting product price.",
    f"Decision Tree Regressor model achieved a mean R2 score of {dt_mean:.4f} (std: {dt_std:.4f}) across 5-fold cross-validation for predicting product price."
]

# This will be used in the final summary block
global_summary_data = {
    "insights": insights,
    "model_evaluations": model_evaluations
}
