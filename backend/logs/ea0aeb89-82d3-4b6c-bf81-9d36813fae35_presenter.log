# Calculate total revenue per product category
category_revenue = df.groupby('product_category_name')['price'].sum().sort_values(ascending=False)

# Get the top 10 product categories
top_10_categories = category_revenue.head(10)

plt.figure(figsize=(12, 8))
sns.barplot(x=top_10_categories.values, y=top_10_categories.index,
            hue=top_10_categories.index, palette='muted', legend=False)
plt.title('Top 10 Product Categories by Total Revenue', fontsize=16)
plt.xlabel('Total Revenue ($)', fontsize=12)
plt.ylabel('Product Category', fontsize=12)
plt.xticks(fontsize=10)
plt.yticks(fontsize=10)
plt.grid(axis='x', linestyle='--', alpha=0.7)

# Annotate the bars with revenue values
for index, value in enumerate(top_10_categories.values):
    plt.text(value, index, f'${value:,.2f}', va='center', ha='left', fontsize=9)

plt.tight_layout()
plt.savefig('/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/ea0aeb89-82d3-4b6c-bf81-9d36813fae35/top_10_product_categories_revenue.png')
