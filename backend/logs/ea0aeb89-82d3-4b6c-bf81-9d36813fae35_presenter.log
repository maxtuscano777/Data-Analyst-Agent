# Convert timestamp columns to datetime objects
df['order_purchase_timestamp'] = pd.to_datetime(df['order_purchase_timestamp'])
df['order_delivered_customer_date'] = pd.to_datetime(df['order_delivered_customer_date'])

# Calculate delivery time in days
df['delivery_time'] = (df['order_delivered_customer_date'] - df['order_purchase_timestamp']).dt.total_seconds() / (24 * 3600)

# Drop NaN values that might result from missing delivery dates
delivery_times = df['delivery_time'].dropna()

# Calculate the median delivery time
median_delivery_time = delivery_times.median()

plt.figure(figsize=(12, 8))
sns.histplot(delivery_times, bins=50, kde=True, color='skyblue')
plt.title('Distribution of Delivery Times', fontsize=16)
plt.xlabel('Delivery Time (Days)', fontsize=12)
plt.ylabel('Number of Orders', fontsize=12)
plt.xticks(fontsize=10)
plt.yticks(fontsize=10)
plt.grid(axis='y', linestyle='--', alpha=0.7)

# Add a vertical line for the median delivery time
plt.axvline(median_delivery_time, color='red', linestyle='--', label=f'Median Delivery Time: {median_delivery_time:.2f} days')
plt.legend()

plt.tight_layout()
plt.savefig('/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/ea0aeb89-82d3-4b6c-bf81-9d36813fae35/delivery_time_distribution.png')
plt.close('all')
print("Saved: delivery_time_distribution.png")

