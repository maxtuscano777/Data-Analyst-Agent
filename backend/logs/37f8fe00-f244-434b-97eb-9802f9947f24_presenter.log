product_category_revenue = df.groupby('product_category_name')['price'].sum().sort_values(ascending=False).head(10)

plt.figure(figsize=(12, 8))
sns.barplot(x=product_category_revenue.values, y=product_category_revenue.index, hue=product_category_revenue.index, palette='muted', legend=False)
plt.title('Top 10 Product Categories by Total Revenue', fontsize=16)
plt.xlabel('Total Revenue', fontsize=12)
plt.ylabel('Product Category', fontsize=12)
plt.xticks(fontsize=10)
plt.yticks(fontsize=10)

for index, value in enumerate(product_category_revenue.values):
    plt.text(value, index, f'{value:,.2f}', va='center', ha='left', fontsize=10)

plt.tight_layout()
plt.savefig(r'/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/37f8fe00-f244-434b-97eb-9802f9947f24/top_product_categories_revenue.png')
