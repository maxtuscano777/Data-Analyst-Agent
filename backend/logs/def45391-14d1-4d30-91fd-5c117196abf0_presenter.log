plt.figure(figsize=(12, 8))
sns.histplot(df['delivery_delay'], bins=50, kde=True, color='skyblue')

mean_delay = df['delivery_delay'].mean()
median_delay = df['delivery_delay'].median()
std_delay = df['delivery_delay'].std()
late_deliveries_percentage = (df['delivery_delay'] > 0).mean() * 100

plt.axvline(mean_delay, color='red', linestyle='dashed', linewidth=2, label=f'Mean: {mean_delay:.2f} days')
plt.axvline(median_delay, color='green', linestyle='dashed', linewidth=2, label=f'Median: {median_delay:.2f} days')

plt.title('Distribution of Delivery Delay', fontsize=16)
plt.xlabel('Delivery Delay (Days)', fontsize=12)
plt.ylabel('Number of Orders', fontsize=12)
plt.legend()

# Annotate the percentage of late deliveries
plt.text(0.95, 0.95, f'Late Deliveries: {late_deliveries_percentage:.2f}%',
         transform=plt.gca().transAxes, fontsize=12, color='red', ha='right', va='top',
         bbox=dict(boxstyle="round,pad=0.3", fc="yellow", ec="b", lw=1, alpha=0.5))

plt.tight_layout()
