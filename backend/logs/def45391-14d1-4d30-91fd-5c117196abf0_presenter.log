# Convert 'delivery_delay' to numeric, coercing errors
df['delivery_delay'] = pd.to_numeric(df['delivery_delay'], errors='coerce')

# Drop rows where 'delivery_delay' is NaN after conversion
df_cleaned_delay = df.dropna(subset=['delivery_delay'])

plt.figure(figsize=(12, 8))
sns.histplot(df_cleaned_delay['delivery_delay'], bins=50, kde=True, color='skyblue')

mean_delay = df_cleaned_delay['delivery_delay'].mean()
median_delay = df_cleaned_delay['delivery_delay'].median()
std_delay = df_cleaned_delay['delivery_delay'].std()
late_deliveries_percentage = (df_cleaned_delay['delivery_delay'] > 0).mean() * 100

plt.axvline(mean_delay, color='red', linestyle='dashed', linewidth=2, label=f'Mean: {mean_delay:.2f} days')
plt.axvline(median_delay, color='green', linestyle='dashed', linewidth=2, label=f'Median: {median_delay:.2f} days')

plt.title('Distribution of Delivery Delay', fontsize=16)
plt.xlabel('Delivery Delay (Days)', fontsize=12)
