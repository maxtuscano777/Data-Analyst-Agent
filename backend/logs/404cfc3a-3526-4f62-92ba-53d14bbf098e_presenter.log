df['order_purchase_timestamp'] = pd.to_datetime(df['order_purchase_timestamp'])
df['order_delivered_customer_date'] = pd.to_datetime(df['order_delivered_customer_date'])

df['delivery_time_days'] = (df['order_delivered_customer_date'] - df['order_purchase_timestamp']).dt.days

# Filter out orders that were not delivered or have invalid delivery times (e.g., negative)
delivery_times = df['delivery_time_days'].dropna()
delivery_times = delivery_times[delivery_times >= 0]

median_delivery_time = delivery_times.median()

plt.figure(figsize=(12, 7))
sns.histplot(delivery_times, bins=50, kde=True, color='skyblue')
plt.axvline(median_delivery_time, color='red', linestyle='--', label=f'Median Delivery Time: {median_delivery_time:.2f} days')
plt.title('Distribution of Order Delivery Times', fontsize=16)
plt.xlabel('Delivery Time (Days)', fontsize=12)
plt.ylabel('Number of Orders', fontsize=12)
plt.legend()
plt.grid(True, linestyle='--', alpha=0.7)
plt.tight_layout()
plt.savefig(r"/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/404cfc3a-3526-4f62-92ba-53d14bbf098e/delivery_time_distribution.png")
plt.close('all')
print("Saved delivery_time_distribution.png")

