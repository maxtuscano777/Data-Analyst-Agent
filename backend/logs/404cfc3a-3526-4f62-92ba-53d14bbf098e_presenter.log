df['total_revenue'] = df['price'] + df['freight_value']

category_revenue = df.groupby('product_category_name')['total_revenue'].sum().reset_index()
category_revenue = category_revenue.sort_values(by='total_revenue', ascending=False)

top_10_categories = category_revenue.head(10)

plt.figure(figsize=(14, 8))
sns.barplot(x='total_revenue', y='product_category_name', data=top_10_categories, hue='product_category_name', palette='muted', legend=False)

plt.title('Top 10 Product Categories by Total Revenue', fontsize=16)
plt.xlabel('Total Revenue', fontsize=12)
plt.ylabel('Product Category', fontsize=12)

# Add annotations to the bars
for index, row in top_10_categories.iterrows():
    plt.text(row['total_revenue'], index, f'{row['total_revenue']:.2f}', color='black', ha="left", va="center")

plt.grid(axis='x', linestyle='--', alpha=0.7)
plt.tight_layout()
plt.savefig(r"/Users/parasjadhav/Desktop/StevensAcademics/Sem_4/GenAI/Project/Data-Analyst-Agent/backend/charts/final/404cfc3a-3526-4f62-92ba-53d14bbf098e/top_10_product_categories_revenue.png")
