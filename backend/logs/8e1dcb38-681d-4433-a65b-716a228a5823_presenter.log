revenue_by_category = df.groupby('product_category_name')['price'].sum().sort_values(ascending=False)
top_10_categories = revenue_by_category.head(10)

plt.figure(figsize=(12, 8))
sns.barplot(x=top_10_categories.index, y=top_10_categories.values, hue=top_10_categories.index, palette='muted', legend=False)
plt.title('Top 10 Product Categories by Total Revenue', fontsize=16)
plt.xlabel('Product Category', fontsize=12)
plt.ylabel('Total Revenue ($)', fontsize=12)
plt.xticks(rotation=45, ha='right')

for index, value in enumerate(top_10_categories.values):
