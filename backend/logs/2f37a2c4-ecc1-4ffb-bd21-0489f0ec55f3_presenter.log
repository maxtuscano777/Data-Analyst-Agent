# Calculate total revenue per product category
category_revenue = df.groupby('product_category_name')['payment_value'].sum().sort_values(ascending=False)

# Get the top 10 product categories
top_10_categories = category_revenue.head(10)

# Create the bar chart for top 10 product categories
