# Copy this file to .env and fill in your values.
DEFAULT_LLM_MODEL=gemini-2.5-flash

# ── Required ───────────────────────────────────────────────────────────────────
# Google Cloud project ID that has the Vertex AI API enabled.
GCP_PROJECT=your-gcp-project-id

# ── Optional ───────────────────────────────────────────────────────────────────
# Vertex AI regional endpoint. Defaults to us-central1 if not set.
GCP_LOCATION=us-central1

# ── Authentication ─────────────────────────────────────────────────────────────
# Option A (recommended): run `gcloud auth application-default login` — no file needed.
# Option B: point to a service account key JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json
